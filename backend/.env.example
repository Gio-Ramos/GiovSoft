PORT=4000
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8080

# Email notifications. Required to send autoresponse and admin notifications.
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=app-password-de-google
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@example.com
SMTP_PASS=contraseña-o-app-password
SMTP_FROM="GiovSoft <usuario@example.com>"
ADMIN_EMAIL=contacto@giovsoft.com
