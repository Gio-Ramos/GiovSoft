PORT=4000
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:8080

# Email notifications. Required to send autoresponse and admin notifications.
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=app-password-de-google
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@example.com
SMTP_PASS=contraseña-o-app-password
SMTP_FROM="GiovSoft <usuario@example.com>"
ADMIN_EMAIL=contacto@giovsoft.com

# Admin panel access. Change these values in production.
ADMIN_NAME=Giovanni Ramos
ADMIN_PASSWORD=GiovSoft2026!
ADMIN_TOKEN_SECRET=cambia-este-secreto-largo-en-produccion
ADMIN_TOKEN_TTL_HOURS=12
# New and reset users receive temporary password 123456 and must change it on next login.

# Hidden master account. Do not commit real values; configure them in backend/.env.
MASTER_ADMIN_NAME=Master GiovSoft
MASTER_ADMIN_EMAIL=master@giovsoft.com
MASTER_ADMIN_PASSWORD=usa-una-contrasena-larga-y-secreta
